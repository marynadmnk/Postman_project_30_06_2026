      "item": [
        {
          "name": "Create Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Has ID', function () {",
                  "    pm.expect(json.id).to.exist;",
                  "});",
                  "",
                  "pm.environment.set('comment_id', json.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "apikey",
              "apikey": [
                {
                  "key": "value",
                  "value": "{{token}}",
                  "type": "string"
                },
                {
                  "key": "key",
                  "value": "Authorization",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment_text\": \"Initial comment from Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/list/{{list_id}}/comment",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "list",
                "{{list_id}}",
                "comment"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Created Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Correct comment returned', function () {",
                  "    let json;",
                  "    try {",
                  "        json = pm.response.json();",
                  "    } catch (e) {",
                  "        pm.expect.fail('Response is not valid JSON: ' + pm.response.text());",
                  "        return;",
                  "    }",
                  "",
                  "    const comments = json.comments || json;",
                  "    pm.expect(comments).to.be.an('array');",
                  "",
                  "    const targetId = pm.environment.get('comment_id');",
                  "    const found = comments.some(function (c) {",
                  "        return String(c.id) === String(targetId);",
                  "    });",
                  "    pm.expect(found, 'Comment with id ' + targetId + ' not found in response').to.be.true;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
